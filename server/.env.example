# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Databases
CITIES_DB=cities_info
USERS_DB=users_auth
TRANSLATIONS_DB=translation_history
PHRASES_DB=phrases_vocabulary

# Smartcat API
SMARTCAT_BASE_URL=https://us.smartcat.ai
SMARTCAT_ACCOUNT_ID=your-smartcat-account-id
SMARTCAT_API_KEY=your-smartcat-api-key
SMARTCAT_PROFILE_ID=your-smartcat-profile-id

# Ticketmaster API
TICKETMASTER_API_KEY=your-ticketmaster-api-key

# JWT — generate a random 256-bit hex string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
