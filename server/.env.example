# Application
APP_NAME=MyTranslationBuddy
APP_VERSION=1.0.0
DEBUG=True

# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=translation_buddy

# Auth
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (JSON list)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# LibreTranslate — set to your hosted instance (same server: http://127.0.0.1:5000)
TRANSLATION_API_BASE_URL=http://localhost:5000
TRANSLATION_TIMEOUT=20
